<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="havoc">

  <!-- 1/10 scale ackermann RC car, rough Tamiya-buggy proportions. -->
  <xacro:property name="body_length" value="0.43"/>
  <xacro:property name="body_width"  value="0.20"/>
  <xacro:property name="body_height" value="0.10"/>
  <xacro:property name="body_mass"   value="2.5"/>

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="wheel_mass"   value="0.15"/>

  <xacro:property name="wheelbase" value="0.265"/>
  <xacro:property name="track"     value="0.21"/>

  <!-- Max steering angle: ~30 deg, typical for a 1/10 RC. -->
  <xacro:property name="steer_limit" value="0.524"/>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12.0}" iyz="0"
               izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12.0}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+l*l)/12.0}" iyz="0"
               izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel_visual_collision">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
  </xacro:macro>

  <!-- Rear (driven) wheel: continuous joint attached directly to base_link. -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_link">
      <xacro:wheel_visual_collision/>
      <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <origin xyz="${x} ${y} ${wheel_radius}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Front (steered) wheel: kingpin link + revolute steer joint + continuous wheel joint. -->
  <xacro:macro name="steered_wheel" params="name x y">
    <link name="${name}_steer_link">
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>
    <joint name="${name}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${name}_steer_link"/>
      <origin xyz="${x} ${y} ${wheel_radius}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-steer_limit}" upper="${steer_limit}" effort="2.0" velocity="3.0"/>
    </joint>

    <link name="${name}_link">
      <xacro:wheel_visual_collision/>
      <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="${name}_steer_link"/>
      <child  link="${name}_link"/>
      <origin xyz="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${wheel_radius + body_height/2.0}"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="red"><color rgba="0.7 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 ${wheel_radius + body_height/2.0}"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
    <xacro:box_inertia m="${body_mass}" x="${body_length}" y="${body_width}" z="${body_height}"/>
  </link>

  <xacro:steered_wheel name="front_left"  x="${ wheelbase/2.0}" y="${ track/2.0}"/>
  <xacro:steered_wheel name="front_right" x="${ wheelbase/2.0}" y="${-track/2.0}"/>
  <xacro:wheel         name="rear_left"   x="${-wheelbase/2.0}" y="${ track/2.0}"/>
  <xacro:wheel         name="rear_right"  x="${-wheelbase/2.0}" y="${-track/2.0}"/>

  <!-- ====================================================================
       Depth camera. Mounted at the front of the chassis where the real
       RealSense D435i will live, tilted ~10 deg down. Two links:
       camera_link is the physical mount (robot frame, Z-up); the optical
       frame (Z-forward, Y-down, X-right) is what perception code expects
       and is what the sensor's published frame_id refers to.
       ==================================================================== -->
  <xacro:property name="camera_x"    value="${body_length/2.0 - 0.02}"/>
  <xacro:property name="camera_z"    value="${wheel_radius + body_height + 0.015}"/>
  <xacro:property name="camera_tilt" value="0.175"/>  <!-- ~10 deg down -->

  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
      <material name="dark_grey"><color rgba="0.15 0.15 0.15 1"/></material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 ${camera_tilt} 0"/>
  </joint>

  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <camera>
        <horizontal_fov>1.21</horizontal_fov>  <!-- ~69 deg, D435i RGB FOV -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <optical_frame_id>camera_optical_link</optical_frame_id>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic>
      <gz_frame_id>camera_optical_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- ====================================================================
       IMU at chassis center. On real hardware this is the MCU-side IMU
       on the SAM E70's PCB; here it's just a Gazebo IMU sensor publishing
       acceleration + angular velocity at 200 Hz for SLAM to consume.
       ==================================================================== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${wheel_radius + body_height/2.0}"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>200</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo ackermann_steering plugin: drives rear wheels, steers front wheels,
       listens on the gz topic 'cmd_vel' for Twist messages. -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>rear_left_joint</left_joint>
      <right_joint>rear_right_joint</right_joint>
      <left_steering_joint>front_left_steer_joint</left_steering_joint>
      <right_steering_joint>front_right_steer_joint</right_steering_joint>
      <kingpin_width>${track}</kingpin_width>
      <steering_limit>${steer_limit}</steering_limit>
      <wheel_base>${wheelbase}</wheel_base>
      <wheel_separation>${track}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
    </plugin>
  </gazebo>

</robot>
